    <h2 class="section-title">system.audio_player() 🎶</h2>
    <audio id="bgMusic"></audio>

    <!-- FIXED POPUP CONSOLE (CENTERED & LAYER TOP) -->
    <div id="consoleModal" class="console-modal">
        <div class="console-header">>_ response_log.json</div>
        <div class="console-json" id="jsonOutput"></div>
        <button class="close-console" onclick="closeConsole()">clear</button>
    </div>

    <script>
        const songs = [
            "https://raw.githubusercontent.com/aniketsingh060714-png/happy-birthday-khirred-/main/Lana Del Rey - Young and Beautiful.mp3",
            "https://raw.githubusercontent.com/aniketsingh060714-png/happy-birthday-khirred-/main/Lana Del Rey - Brooklyn Baby (Official Audio).mp3"
        ];

        let index = 0;
        const player = document.getElementById("bgMusic");

        function playSong(i){
            player.src = songs[i];
            player.play().catch(err => console.log("Audio play deferred until interaction"));
        }

        player.addEventListener("ended", function(){
            index = (index + 1) % songs.length;
            playSong(index);
        });

        document.body.addEventListener("click", function () {
            if(!player.src) playSong(index);
        }, { once: true });

        // FIXED POPUP FOR SCREEN CENTER DISPLAY
        function showLove(){
            const modal = document.getElementById("consoleModal");
            const jsonBox = document.getElementById("jsonOutput");
            
            const loveData = {
                "status": 200,
                "connection": "Stable & Infinite",
                "message": "Out of billions of data points in the universe...",
                "result": "I am officially the luckiest because I found you. ❤️",
                "wish": "Happy Birthday My Sweetuuu! 💜",
                "database_sync": "100% Core Memory Saved"
            };

            jsonBox.textContent = JSON.stringify(loveData, null, 2);
            modal.style.display = "block";
            modal.classList.add("active");
        }

        function closeConsole(){
            document.getElementById("consoleModal").style.display = "none";
            document.getElementById("consoleModal").classList.remove("active");
        }

        // TEDDY DIALOGUE SYSTEM
        const teddyQuotes = [
            "Aniket loves you more than JavaScript loves bugs! 💻❤️",
            "Warning: System overload due to extreme cuteness! 📉😍",
            "You are the CSS to his HTML, you keep him perfectly styled! ✨",
            "Database Status: 1 Year Completed successfully! Loading forever... ⏳",
            "Happy Birthday, Sweetuuu! May your console always be free of errors! 💜"
        ];
        let currentQuoteIndex = 0;

        function teddySpeak() {
            const bubble = document.getElementById("teddySpeech");
            bubble.textContent = teddyQuotes[currentQuoteIndex];
            currentQuoteIndex = (currentQuoteIndex + 1) % teddyQuotes.length;
        }

        // GENERATE FLOATING HEARTS AUTOMATICALLY
        function createHearts() {
            for(let i=0; i<25; i++){
                let h = document.createElement("div");
                h.className = "heart";
                h.innerHTML = i % 2 === 0 ? "💜" : "❤️";
                h.style.left = Math.random() * 100 + "%";
                h.style.top = "0px";
                h.style.fontSize = (15 + Math.random() * 20) + "px";
                h.style.animationDuration = (6 + Math.random() * 5) + "s";
                h.style.animationDelay = (Math.random() * 5) + "s";
                document.body.appendChild(h);
            }
        }
        
        window.onload = createHearts;
    </script>

</body>
