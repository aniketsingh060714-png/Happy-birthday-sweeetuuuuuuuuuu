<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>system.init("Happy Birthday, Maryam") 💜</title>

    <style>
        :root {
            --primary: #8e44ad;
            --secondary: #c084fc;
            --dark-bg: #0d0e15;
            --card-bg: rgba(20, 20, 35, 0.65);
            --border: rgba(192, 132, 252, 0.25);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: radial-gradient(circle at top, #1e1135 0%, var(--dark-bg) 70%);
            color: #f3e8ff;
            text-align: center;
            overflow-x: hidden;
            min-height: 100vh;
            padding-bottom: 50px;
        }

        /* DEVELOPER TERMINAL WINDOW */
        .terminal-window {
            width: 90%;
            max-width: 650px;
            margin: 50px auto 30px auto;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(142, 68, 173, 0.2);
            overflow: hidden;
            animation: renderApp 1.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .terminal-header {
            background: rgba(10, 10, 15, 0.8);
            padding: 12px 20px;
            display: flex;
            align-items: center;
            border-bottom: 1px solid var(--border);
        }

        .terminal-buttons {
            display: flex;
            gap: 8px;
        }

        .dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }
        .dot.red { background: #ff5f56; }
        .dot.yellow { background: #ffbd2e; }
        .dot.green { background: #27c93f; }

        .terminal-title {
            margin: 0 auto;
            font-family: 'Courier New', Courier, monospace;
            font-size: 13px;
            color: #a78bfa;
            letter-spacing: 1px;
            transform: translateX(-16px);
        }

        .card-content {
            padding: 35px 25px;
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 25px;
            background: linear-gradient(to right, #fff, var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .letter-text {
            line-height: 1.9;
            font-size: 16px;
            text-align: left;
            max-width: 500px;
            margin: 0 auto;
            color: #e2d5f3;
            border-left: 2px solid rgba(192, 132, 252, 0.4);
            padding-left: 20px;
        }

        .letter-text br {
            content: "";
            margin: 10px 0;
            display: block;
        }

        .signature {
            margin-top: 25px;
            font-weight: 600;
            color: #fff;
        }

        /* TEDDY BEAR ANIMATED COMPONENT */
        .teddy-container {
            margin: 40px auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            max-width: 500px;
            position: relative;
        }

        .teddy-bubble {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid var(--border);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 15px 25px;
            color: #f3e8ff;
            font-size: 16px;
            font-weight: 500;
            margin-bottom: 20px;
            position: relative;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            animation: bounce 3s infinite ease-in-out;
            max-width: 85%;
        }

        .teddy-bubble::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 10px 10px 0;
            border-style: solid;
            border-color: rgba(255, 255, 255, 0.1) transparent;
            display: block;
            width: 0;
        }

        .teddy {
            width: 150px;
            height: 150px;
            position: relative;
            cursor: pointer;
        }

        .teddy-ear-left, .teddy-ear-right {
            width: 45px;
            height: 45px;
            background: #a16207;
            border-radius: 50%;
            position: absolute;
            top: 5px;
        }
        .teddy-ear-left { left: 10px; }
        .teddy-ear-right { right: 10px; }

        .teddy-ear-left::after, .teddy-ear-right::after {
            content: '';
            width: 25px;
            height: 25px;
            background: #fda4af;
            border-radius: 50%;
            position: absolute;
            top: 10px;
            left: 10px;
        }

        .teddy-head {
            width: 120px;
            height: 110px;
            background: #ca8a04;
            border-radius: 50% 50% 45% 45%;
            position: absolute;
            top: 25px;
            left: 15px;
            box-shadow: inset -5px -5px 0px rgba(0,0,0,0.15);
        }

        .teddy-eye-left, .teddy-eye-right {
            width: 12px;
            height: 12px;
            background: #0f172a;
            border-radius: 50%;
            position: absolute;
            top: 45px;
            animation: blink 4s infinite;
        }
        .teddy-eye-left { left: 35px; }
        .teddy-eye-right { right: 35px; }

        .teddy-snout {
            width: 45px;
            height: 35px;
            background: #fef08a;
            border-radius: 50%;
            position: absolute;
            top: 60px;
            left: 38px;
        }

        .teddy-nose {
            width: 16px;
            height: 10px;
            background: #0f172a;
            border-radius: 40% 40% 50% 50%;
            position: absolute;
            top: 5px;
            left: 14.5px;
        }

        .teddy-mouth {
            width: 14px;
            height: 8px;
            border: 2px solid #0f172a;
            border-top: none;
            border-radius: 0 0 10px 10px;
            position: absolute;
            top: 16px;
            left: 15.5px;
        }

        /* PREMIUM BUTTON */
        .cta-btn {
            margin-top: 35px;
            padding: 14px 35px;
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 30px;
            font-size: 15px;
            font-weight: 600;
            letter-spacing: 0.5px;
            cursor: pointer;
            background: linear-gradient(135deg, #9333ea 0%, #6b21a8 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(147, 51, 234, 0.4);
            transition: all 0.3s ease;
        }

        .cta-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(147, 51, 234, 0.6);
            border-color: rgba(255, 255, 255, 0.8);
        }

        /* SECTION HEADINGS */
        h2.section-title {
            font-size: 20px;
            margin: 50px 0 20px 0;
            font-family: 'Courier New', Courier, monospace;
            color: #a78bfa;
            display: inline-block;
            border-bottom: 1px dashed rgba(167, 139, 250, 0.4);
            padding-bottom: 5px;
        }

        /* PROFESSIONAL IMAGE GRID */
        .gallery {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 15px;
            max-width: 900px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .gallery img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 8px 16px rgba(0,0,0,0.3);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .gallery img:hover {
            transform: scale(1.06) translateY(-5px);
            border-color: var(--secondary);
            box-shadow: 0 12px 20px rgba(142, 68, 173, 0.3);
        }

        /* FLOATING HEARTS */
        .heart {
            position: absolute;
            font-size: 20px;
            animation: floatUp 7s linear infinite;
            pointer-events: none;
            z-index: 1;
            opacity: 0.6;
        }

        /* FIXED FIXED FIXED CENTER CONSOLE MODAL FOR MOBILE */
        .console-modal {
            display: none;
            position: fixed;
            top: 50% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) scale(1) !important;
            width: 90%;
            max-width: 450px;
            background: #090a0f;
            border: 2px solid #22c55e;
            border-radius: 12px;
            padding: 20px;
            z-index: 99999 !important; /* Ekdum top par rakhne ke liye */
            text-align: left;
            box-shadow: 0 0 50px rgba(34, 197, 94, 0.4), 0 0 100px rgba(0, 0, 0, 0.8);
            font-family: 'Courier New', Courier, monospace;
        }

        .console-modal.active {
            display: block !important;
        }

        .console-header {
            color: #27c93f;
            margin-bottom: 15px;
            font-weight: bold;
            border-bottom: 1px solid rgba(39, 201, 63, 0.2);
            padding-bottom: 8px;
        }

        .console-json {
            color: #a78bfa;
            font-size: 13px;
            white-space: pre-wrap;
            line-height: 1.6;
        }

        .close-console {
            margin-top: 15px;
            background: transparent;
            border: 1px solid #22c55e;
            color: #22c55e;
            padding: 6px 18px;
            cursor: pointer;
            font-family: monospace;
            border-radius: 4px;
            float: right;
            font-weight: bold;
        }

        .close-console:hover {
            background: rgba(34, 197, 94, 0.1);
        }

        /* LAYER ADJUSTMENT */
        .terminal-window, h2, .gallery, .teddy-container {
            position: relative;
            z-index: 10;
        }

        /* ANIMATIONS */
        @keyframes floatUp {
            0% { transform: translateY(105vh) rotate(0deg); opacity: 0; }
            10% { opacity: 0.6; }
            90% { opacity: 0.6; }
            100% { transform: translateY(-15vh) rotate(360deg); opacity: 0; }
        }

        @keyframes renderApp {
            to { transform: translate(-50%, -50%) scale(1); opacity: 1; }
            from { transform: translate(-50%, -40%) scale(0.95); opacity: 0; }
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        @keyframes blink {
            0%, 90%, 100% { transform: scaleY(1); }
            95% { transform: scaleY(0.1); }
        }

        @media (max-width: 600px) {
            .letter-text { font-size: 14px; padding-left: 15px; }
            h1 { font-size: 22px; }
            .gallery { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 10px; }
            .gallery img { height: 110px; }
        }
    </style>
</head>

